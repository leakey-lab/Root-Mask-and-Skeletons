<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" width="256" height="256">
  <defs>
    <!-- Gradients -->
    <linearGradient id="bgGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#1e1e2e" stop-opacity="1" />
      <stop offset="100%" stop-color="#282a36" stop-opacity="1" />
    </linearGradient>
    
    <linearGradient id="maskGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#4CAF50" stop-opacity="0.6" />
      <stop offset="100%" stop-color="#8BC34A" stop-opacity="0.6" />
    </linearGradient>
    
    <linearGradient id="skeletonGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#FF5722" stop-opacity="1" />
      <stop offset="100%" stop-color="#FFC107" stop-opacity="1" />
    </linearGradient>

    <!-- Filters -->
    <filter id="skeletonGlow" x="-50%" y="-50%" width="200%" height="200%">
      <feGaussianBlur stdDeviation="2.5" result="coloredBlur"/>
      <feMerge>
        <feMergeNode in="coloredBlur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
    
    <filter id="textGlow" x="-50%" y="-50%" width="200%" height="200%">
      <feGaussianBlur stdDeviation="2" result="coloredBlur"/>
      <feMerge>
        <feMergeNode in="coloredBlur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>
  
  <!-- Background -->
  <rect width="256" height="256" fill="url(#bgGradient)" rx="14"/>
  
  <!-- LEFT SIDE: Mask/Root Surface -->
  <g>
    <!-- Frame for mask -->
    <rect x="15" y="30" width="100" height="130" rx="14" fill="none" stroke="#4CAF50" stroke-width="1.5" opacity="0.6"/>
    
    <!-- Mask background (semi-transparent root) -->
    <g transform="translate(40, 50)">
      <!-- Main root filled area -->
      <path d="M20 5 Q22 15 20 25 Q18 35 22 45 Q25 55 20 65" fill="url(#maskGradient)" stroke="#4CAF50" stroke-width="8" stroke-linecap="round" opacity="0.7"/>
      
      <!-- Left branches filled -->
      <path d="M20 15 Q10 20 5 30" fill="url(#maskGradient)" stroke="#66BB6A" stroke-width="5" stroke-linecap="round" opacity="0.6"/>
      <path d="M18 30 Q8 38 3 50" fill="url(#maskGradient)" stroke="#8BC34A" stroke-width="3" stroke-linecap="round" opacity="0.5"/>
      
      <!-- Right branches filled -->
      <path d="M22 20 Q32 25 38 38" fill="url(#maskGradient)" stroke="#66BB6A" stroke-width="5" stroke-linecap="round" opacity="0.6"/>
      <path d="M24 40 Q35 48 42 62" fill="url(#maskGradient)" stroke="#8BC34A" stroke-width="3" stroke-linecap="round" opacity="0.5"/>
    </g>
  </g>
  
  <!-- CENTER: AI Processing Arrow & Circles -->
  <g filter="url(#skeletonGlow)">
    <!-- Processing nodes -->
    <circle cx="128" cy="50" r="6" fill="#7C4DFF" stroke="#536DFE" stroke-width="1.5"/>
    <circle cx="128" cy="85" r="6" fill="#536DFE" stroke="#7C4DFF" stroke-width="1.5"/>
    <circle cx="128" cy="120" r="6" fill="#448AFF" stroke="#7C4DFF" stroke-width="1.5"/>
    
    <!-- Connecting lines -->
    <line x1="128" y1="56" x2="128" y2="79" stroke="#7C4DFF" stroke-width="2" opacity="0.7"/>
    <line x1="128" y1="91" x2="128" y2="114" stroke="#536DFE" stroke-width="2" opacity="0.7"/>
  </g>
  
  <!-- RIGHT SIDE: Skeleton (Medial Axis) -->
  <g>
    <!-- Frame for skeleton -->
    <rect x="141" y="30" width="100" height="130" rx="14" fill="none" stroke="#FF5722" stroke-width="2" opacity="0.9"/>
    
    <!-- Skeleton visualization (thin medial axis lines) -->
    <g transform="translate(166, 50)" filter="url(#skeletonGlow)">
      <!-- Main root skeleton -->
      <path d="M20 5 Q22 15 20 25 Q18 35 22 45 Q25 55 20 65" fill="none" stroke="url(#skeletonGradient)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
      
      <!-- Left branch skeletons -->
      <path d="M20 15 Q10 20 5 30" fill="none" stroke="url(#skeletonGradient)" stroke-width="2" stroke-linecap="round"/>
      <path d="M18 30 Q8 38 3 50" fill="none" stroke="url(#skeletonGradient)" stroke-width="1.5" stroke-linecap="round"/>
      
      <!-- Right branch skeletons -->
      <path d="M22 20 Q32 25 38 38" fill="none" stroke="url(#skeletonGradient)" stroke-width="2" stroke-linecap="round"/>
      <path d="M24 40 Q35 48 42 62" fill="none" stroke="url(#skeletonGradient)" stroke-width="1.5" stroke-linecap="round"/>
      
      <!-- Junction nodes -->
      <circle cx="20" cy="5" r="2" fill="#FF5722"/>
      <circle cx="20" cy="25" r="1.5" fill="#FFC107"/>
      <circle cx="22" cy="45" r="1.5" fill="#FFC107"/>
      <circle cx="20" cy="65" r="2" fill="#FF5722"/>
    </g>
  </g>
  
  <!-- Background overlay for main label -->
  <rect x="0" y="200" width="256" height="56" fill="#1e1e2e" opacity="0.9" rx="14" ry="0"/>
  
  <!-- Function label -->
  <text x="128" y="240" text-anchor="middle" fill="#8be9fd" font-size="28" font-weight="bold" font-family="sans-serif" filter="url(#textGlow)">
    Skeletonize
  </text>
</svg>