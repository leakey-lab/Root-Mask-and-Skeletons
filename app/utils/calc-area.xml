<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" width="256" height="256">
  <defs>
    <linearGradient id="bgGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#1e1e2e" stop-opacity="1" />
      <stop offset="100%" stop-color="#282a36" stop-opacity="1" />
    </linearGradient>
    <linearGradient id="buttonGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#50fa7b" stop-opacity="0.2" />
      <stop offset="100%" stop-color="#50fa7b" stop-opacity="0.1" />
    </linearGradient>
    <linearGradient id="areaGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#4CAF50" stop-opacity="0.9" />
      <stop offset="100%" stop-color="#8BC34A" stop-opacity="0.9" />
    </linearGradient>
    <linearGradient id="calcGradient" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" stop-color="#50fa7b" stop-opacity="1" />
      <stop offset="100%" stop-color="#8BC34A" stop-opacity="1" />
    </linearGradient>
    <filter id="glow" x="-50%" y="-50%" width="200%" height="200%">
      <feGaussianBlur stdDeviation="3" result="coloredBlur"/>
      <feMerge>
        <feMergeNode in="coloredBlur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
    <filter id="textGlow" x="-50%" y="-50%" width="200%" height="200%">
      <feGaussianBlur stdDeviation="2" result="coloredBlur"/>
      <feMerge>
        <feMergeNode in="coloredBlur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>
  
  <!-- Background -->
  <rect width="256" height="256" fill="url(#bgGradient)" rx="12"/>
  
  <!-- Button background -->
  <rect x="8" y="8" width="240" height="240" rx="10" ry="10" 
        fill="url(#buttonGradient)" stroke="#50fa7b" stroke-width="2"/>
  
  <!-- AREA indicator - Filled square with grid - expanded to fill most of canvas -->
  <g filter="url(#glow)">
    <!-- Main square area - larger -->
    <rect x="40" y="35" width="176" height="176" rx="8" ry="8"
          fill="url(#areaGradient)" stroke="#4CAF50" stroke-width="3"/>
    
    <!-- Grid lines inside square - finer grid -->
    <g stroke="#2E7D32" stroke-width="1.5" opacity="0.6">
      <line x1="80" y1="35" x2="80" y2="211"/>
      <line x1="120" y1="35" x2="120" y2="211"/>
      <line x1="160" y1="35" x2="160" y2="211"/>
      <line x1="40" y1="75" x2="216" y2="75"/>
      <line x1="40" y1="115" x2="216" y2="115"/>
      <line x1="40" y1="155" x2="216" y2="155"/>
      <line x1="40" y1="195" x2="216" y2="195"/>
    </g>
    
    <!-- Corner markers - larger -->
    <circle cx="40" cy="35" r="6" fill="#8BC34A"/>
    <circle cx="216" cy="35" r="6" fill="#8BC34A"/>
    <circle cx="40" cy="211" r="6" fill="#8BC34A"/>
    <circle cx="216" cy="211" r="6" fill="#8BC34A"/>
    
    <!-- Area symbol - larger -->
    <text x="128" y="125" text-anchor="middle" fill="#FFFFFF" font-size="56" font-weight="bold" font-family="sans-serif">A</text>
  </g>
  
  <!-- Function label - large text -->
  <text x="128" y="245" text-anchor="middle" fill="#50fa7b" font-size="24" font-weight="bold" font-family="sans-serif" filter="url(#textGlow)">
    Calculate Area
  </text>
</svg>
