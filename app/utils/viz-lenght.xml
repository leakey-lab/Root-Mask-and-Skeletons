<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" width="256" height="256">
  <defs>
    <linearGradient id="bgGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#282a36" stop-opacity="1" />
      <stop offset="100%" stop-color="#1e1e2e" stop-opacity="1" />
    </linearGradient>
    <linearGradient id="lineGradient" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" stop-color="#ff79c6" stop-opacity="1" />
      <stop offset="50%" stop-color="#bd93f9" stop-opacity="1" />
      <stop offset="100%" stop-color="#ff79c6" stop-opacity="1" />
    </linearGradient>
  </defs>
  
  <!-- Background -->
  <rect width="256" height="256" fill="url(#bgGradient)" rx="14"/>
  
  <!-- Main icon: Line chart -->
  <g transform="translate(128, 128)">
    <!-- Chart line -->
    <polyline points="-70,10 -35,-20 0,-10 35,-60 70,-80" 
              fill="none" stroke="url(#lineGradient)" stroke-width="5" stroke-linecap="round" stroke-linejoin="round"/>
    
    <!-- Data points - chart brought up (all y values subtracted by 40) -->
    <circle cx="-70" cy="10" r="5" fill="#ff79c6" stroke="#fff" stroke-width="2"/>
    <circle cx="-35" cy="-20" r="5" fill="#bd93f9" stroke="#fff" stroke-width="2"/>
    <circle cx="0" cy="-10" r="5" fill="#ff79c6" stroke="#fff" stroke-width="2"/>
    <circle cx="35" cy="-60" r="5" fill="#bd93f9" stroke="#fff" stroke-width="2"/>
    <circle cx="70" cy="-80" r="5" fill="#ff79c6" stroke="#fff" stroke-width="2"/>
  </g>
  
  <!-- Button label - Maximum 2 words, large text -->
  <text x="128" y="230" text-anchor="middle" fill="#ff79c6" font-size="32" font-weight="bold" font-family="Arial, sans-serif">
    Visualize Length
  </text>
</svg>
