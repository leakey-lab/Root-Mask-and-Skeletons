<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" width="256" height="256">
  <defs>
    <linearGradient id="bgGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#1e1e2e" stop-opacity="1" />
      <stop offset="100%" stop-color="#282a36" stop-opacity="1" />
    </linearGradient>
    <linearGradient id="buttonGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#50fa7b" stop-opacity="0.2" />
      <stop offset="100%" stop-color="#50fa7b" stop-opacity="0.1" />
    </linearGradient>
    <linearGradient id="rulerGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#7C4DFF" stop-opacity="1" />
      <stop offset="100%" stop-color="#536DFE" stop-opacity="1" />
    </linearGradient>
    <linearGradient id="lineGradient" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" stop-color="#4CAF50" stop-opacity="1" />
      <stop offset="100%" stop-color="#8BC34A" stop-opacity="1" />
    </linearGradient>
    <filter id="glow" x="-50%" y="-50%" width="200%" height="200%">
      <feGaussianBlur stdDeviation="3" result="coloredBlur"/>
      <feMerge>
        <feMergeNode in="coloredBlur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
    <filter id="textGlow" x="-50%" y="-50%" width="200%" height="200%">
      <feGaussianBlur stdDeviation="2" result="coloredBlur"/>
      <feMerge>
        <feMergeNode in="coloredBlur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>
  
  <!-- Background -->
  <rect width="256" height="256" fill="url(#bgGradient)" rx="12"/>
  
  <!-- Button background -->
  <rect x="8" y="8" width="240" height="240" rx="10" ry="10" 
        fill="url(#buttonGradient)" stroke="#50fa7b" stroke-width="2"/>
  
  <!-- Ruler body and measurement line - expanded -->
  <g transform="translate(0, 0)">
    <!-- Ruler body - larger -->
    <rect x="20" y="40" width="216" height="50" rx="8" ry="8" 
          fill="url(#rulerGradient)" stroke="#9575CD" stroke-width="2"/>
    
    <!-- Ruler tick marks - more prominent -->
    <g stroke="#E0E0E0" stroke-width="2.5">
      <!-- Major ticks -->
      <line x1="50" y1="40" x2="50" y2="70"/>
      <line x1="90" y1="40" x2="90" y2="70"/>
      <line x1="130" y1="40" x2="130" y2="70"/>
      <line x1="170" y1="40" x2="170" y2="70"/>
      <line x1="210" y1="40" x2="210" y2="70"/>
      <!-- Minor ticks -->
      <line x1="70" y1="40" x2="70" y2="60"/>
      <line x1="110" y1="40" x2="110" y2="60"/>
      <line x1="150" y1="40" x2="150" y2="60"/>
      <line x1="190" y1="40" x2="190" y2="60"/>
    </g>
  </g>
  
  <!-- LENGTH indicator - Horizontal line with endpoints - expanded -->
  <g filter="url(#glow)">
    <!-- Main measurement line - larger -->
    <line x1="30" y1="145" x2="226" y2="145" 
          stroke="url(#lineGradient)" stroke-width="10" stroke-linecap="round"/>
    
    <!-- Left endpoint marker - larger -->
    <line x1="30" y1="125" x2="30" y2="165" 
          stroke="#4CAF50" stroke-width="7" stroke-linecap="round"/>
    
    <!-- Right endpoint marker - larger -->
    <line x1="226" y1="125" x2="226" y2="165" 
          stroke="#8BC34A" stroke-width="7" stroke-linecap="round"/>
    
    <!-- Measurement arrows -->
    <polygon points="50,145 65,133 65,157" fill="#4CAF50"/>
    <polygon points="206,145 191,133 191,157" fill="#8BC34A"/>
    
    <!-- Length symbol - much larger -->
    <text x="128" y="155" text-anchor="middle" fill="#FFFFFF" font-size="52" font-weight="bold" font-family="sans-serif">L</text>
  </g>
  
  <!-- Function label - large text -->
  <text x="128" y="245" text-anchor="middle" fill="#50fa7b" font-size="24" font-weight="bold" font-family="sans-serif" filter="url(#textGlow)">
    Calculate Length
  </text>
</svg>