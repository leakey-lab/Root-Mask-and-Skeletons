<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" width="256" height="256">
  <defs>
    <linearGradient id="bgGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#282a36" stop-opacity="1" />
      <stop offset="100%" stop-color="#1e1e2e" stop-opacity="1" />
    </linearGradient>
    <linearGradient id="barGradient1" x1="0%" y1="100%" x2="0%" y2="0%">
      <stop offset="0%" stop-color="#ff79c6" stop-opacity="1" />
      <stop offset="100%" stop-color="#bd93f9" stop-opacity="1" />
    </linearGradient>
    <linearGradient id="barGradient2" x1="0%" y1="100%" x2="0%" y2="0%">
      <stop offset="0%" stop-color="#ff79c6" stop-opacity="0.8" />
      <stop offset="100%" stop-color="#bd93f9" stop-opacity="0.8" />
    </linearGradient>
    <linearGradient id="barGradient3" x1="0%" y1="100%" x2="0%" y2="0%">
      <stop offset="0%" stop-color="#ff79c6" stop-opacity="0.9" />
      <stop offset="100%" stop-color="#bd93f9" stop-opacity="0.9" />
    </linearGradient>
  </defs>
  
  <!-- Background -->
  <rect width="256" height="256" fill="url(#bgGradient)" rx="8"/>
  
  <!-- Main icon: Bar chart -->
  <g transform="translate(128, 90)">
    <!-- Chart bars (all y values brought up by 30 units) -->
    <rect x="-70" y="-10" width="25" height="60" rx="3" fill="url(#barGradient1)"/>
    <rect x="-35" y="-40" width="25" height="90" rx="3" fill="url(#barGradient2)"/>
    <rect x="0" y="-20" width="25" height="70" rx="3" fill="url(#barGradient3)"/>
    <rect x="35" y="-60" width="25" height="110" rx="3" fill="url(#barGradient1)"/>
    
    <!-- Chart base line (also moved up by 30 units) -->
    <line x1="-80" y1="50" x2="70" y2="50" 
          stroke="#6272a4" stroke-width="2" stroke-linecap="round"/>
  </g>
  
  <!-- Button label - Maximum 2 words, large text -->
  <text x="128" y="230" text-anchor="middle" fill="#ff79c6" font-size="32" font-weight="bold" font-family="Arial, sans-serif">
    Visualize Area
  </text>
</svg>
