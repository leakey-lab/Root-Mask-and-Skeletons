<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" width="256" height="256">
  <defs>
    <!-- Gradients -->
    <linearGradient id="bgGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#1e1e2e" stop-opacity="1" />
      <stop offset="100%" stop-color="#282a36" stop-opacity="1" />
    </linearGradient>
    
    <linearGradient id="maskGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#FF5722" stop-opacity="1" />
      <stop offset="100%" stop-color="#FF9800" stop-opacity="1" />
    </linearGradient>
    
    <linearGradient id="rootGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#4CAF50" stop-opacity="1" />
      <stop offset="100%" stop-color="#8BC34A" stop-opacity="1" />
    </linearGradient>

    <!-- Filters -->
    <filter id="glow" x="-50%" y="-50%" width="200%" height="200%">
      <feGaussianBlur stdDeviation="3" result="coloredBlur"/>
      <feMerge>
        <feMergeNode in="coloredBlur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
    
    <filter id="textGlow" x="-50%" y="-50%" width="200%" height="200%">
      <feGaussianBlur stdDeviation="2" result="coloredBlur"/>
      <feMerge>
        <feMergeNode in="coloredBlur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>
  
  <!-- Background -->
  <rect width="256" height="256" fill="url(#bgGradient)" rx="14"/>
  
  <!-- LEFT SIDE: Original Root Image -->
  <g>
    <!-- Frame for original -->
    <rect x="15" y="30" width="100" height="130" rx="14" fill="none" stroke="#6272a4" stroke-width="1.5" opacity="0.6"/>
    
    <!-- Root visualization (original) -->
    <g transform="translate(40, 50)">
      <!-- Main root -->
      <path d="M20 5 Q22 15 20 25 Q18 35 22 45 Q25 55 20 65" fill="none" stroke="url(#rootGradient)" stroke-width="4" stroke-linecap="round"/>
      
      <!-- Left branches -->
      <path d="M20 15 Q10 20 5 30" fill="none" stroke="#66BB6A" stroke-width="2.5" stroke-linecap="round"/>
      <path d="M18 30 Q8 38 3 50" fill="none" stroke="#8BC34A" stroke-width="2" stroke-linecap="round"/>
      
      <!-- Right branches -->
      <path d="M22 20 Q32 25 38 38" fill="none" stroke="#66BB6A" stroke-width="2.5" stroke-linecap="round"/>
      <path d="M24 40 Q35 48 42 62" fill="none" stroke="#8BC34A" stroke-width="2" stroke-linecap="round"/>
    </g>
  </g>
  
  <!-- CENTER: AI Processing Arrow & Circles -->
  <g filter="url(#glow)">
    <!-- Processing nodes -->
    <circle cx="128" cy="50" r="6" fill="#7C4DFF" stroke="#536DFE" stroke-width="1.5"/>
    <circle cx="128" cy="85" r="6" fill="#536DFE" stroke="#7C4DFF" stroke-width="1.5"/>
    <circle cx="128" cy="120" r="6" fill="#448AFF" stroke="#7C4DFF" stroke-width="1.5"/>
    
    <!-- Connecting lines -->
    <line x1="128" y1="56" x2="128" y2="79" stroke="#7C4DFF" stroke-width="2" opacity="0.7"/>
    <line x1="128" y1="91" x2="128" y2="114" stroke="#536DFE" stroke-width="2" opacity="0.7"/>
  </g>
  
  <!-- RIGHT SIDE: Segmented Mask -->
  <g>
    <!-- Frame for mask -->
    <rect x="141" y="30" width="100" height="130" rx="14" fill="none" stroke="#FF9800" stroke-width="2" opacity="0.9"/>
    
    <!-- Mask visualization (highlighted areas) -->
    <g transform="translate(166, 50)" filter="url(#glow)">
      <!-- Main root mask - thicker and more visible -->
      <path d="M20 5 Q22 15 20 25 Q18 35 22 45 Q25 55 20 65" fill="none" stroke="url(#maskGradient)" stroke-width="6" stroke-linecap="round" opacity="0.95"/>
      
      <!-- Left branches mask -->
      <path d="M20 15 Q10 20 5 30" fill="none" stroke="url(#maskGradient)" stroke-width="5" stroke-linecap="round" opacity="0.9"/>
      <path d="M18 30 Q8 38 3 50" fill="none" stroke="url(#maskGradient)" stroke-width="4" stroke-linecap="round" opacity="0.8"/>
      
      <!-- Right branches mask -->
      <path d="M22 20 Q32 25 38 38" fill="none" stroke="url(#maskGradient)" stroke-width="5" stroke-linecap="round" opacity="0.9"/>
      <path d="M24 40 Q35 48 42 62" fill="none" stroke="url(#maskGradient)" stroke-width="4" stroke-linecap="round" opacity="0.8"/>
    </g>
  </g>
  
  <!-- Background overlay for main label -->
  <rect x="0" y="200" width="256" height="56" fill="#1e1e2e" opacity="0.9" rx="14" ry="0"/>
  
  <!-- Function label -->
  <text x="128" y="240" text-anchor="middle" fill="#8be9fd" font-size="28" font-weight="bold" font-family="sans-serif" filter="url(#textGlow)">
    Segmentation
  </text>
</svg>