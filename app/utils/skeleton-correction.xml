<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" width="256" height="256">
  <defs>
    <!-- Core gradients -->
    <linearGradient id="correctedSkeleton" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#4CAF50" stop-opacity="1" />
      <stop offset="50%" stop-color="#8BC34A" stop-opacity="1" />
      <stop offset="100%" stop-color="#CDDC39" stop-opacity="1" />
    </linearGradient>
    
    <linearGradient id="errorSkeleton" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#FF7043" stop-opacity="0.7" />
      <stop offset="100%" stop-color="#FF5722" stop-opacity="0.7" />
    </linearGradient>
    
    <linearGradient id="correctionGlow" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#7C4DFF" stop-opacity="0.9" />
      <stop offset="100%" stop-color="#536DFE" stop-opacity="0.9" />
    </linearGradient>
    
    <linearGradient id="aiGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#7C4DFF" stop-opacity="1" />
      <stop offset="50%" stop-color="#536DFE" stop-opacity="0.8" />
      <stop offset="100%" stop-color="#448AFF" stop-opacity="1" />
    </linearGradient>
    
    <linearGradient id="arrowGradient" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" stop-color="#00BCD4" stop-opacity="1" />
      <stop offset="100%" stop-color="#4CAF50" stop-opacity="1" />
    </linearGradient>

    <!-- Enhanced filters for better visibility at small sizes -->
    <filter id="skeletonGlow" x="-50%" y="-50%" width="200%" height="200%">
      <feGaussianBlur stdDeviation="2.5" result="blur"/>
      <feFlood flood-color="#8BC34A" flood-opacity="0.6"/>
      <feComposite in2="blur" operator="in"/>
      <feMerge>
        <feMergeNode/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
    
    <filter id="fixGlow" x="-50%" y="-50%" width="200%" height="200%">
      <feGaussianBlur stdDeviation="3.5" result="fixBlur"/>
      <feMerge>
        <feMergeNode in="fixBlur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
    
    <filter id="softGlow" x="-50%" y="-50%" width="200%" height="200%">
      <feGaussianBlur stdDeviation="2.2" result="softBlur"/>
      <feMerge>
        <feMergeNode in="softBlur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
    
    <!-- Text glow filter -->
    <filter id="textGlow" x="-50%" y="-50%" width="200%" height="200%">
      <feGaussianBlur stdDeviation="2" result="coloredBlur"/>
      <feMerge>
        <feMergeNode in="coloredBlur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>

  <!-- Enhanced subtle AI grid overlay - slightly more visible -->
  <g opacity="0.15">
    <line x1="32" y1="0" x2="32" y2="256" stroke="#536DFE" stroke-width="0.7"/>
    <line x1="64" y1="0" x2="64" y2="256" stroke="#536DFE" stroke-width="0.7"/>
    <line x1="96" y1="0" x2="96" y2="256" stroke="#536DFE" stroke-width="0.7"/>
    <line x1="128" y1="0" x2="128" y2="256" stroke="#536DFE" stroke-width="0.7"/>
    <line x1="0" y1="64" x2="256" y2="64" stroke="#536DFE" stroke-width="0.7"/>
    <line x1="0" y1="128" x2="256" y2="128" stroke="#536DFE" stroke-width="0.7"/>
    <line x1="0" y1="192" x2="256" y2="192" stroke="#536DFE" stroke-width="0.7"/>
  </g>

  <!-- Faint segmentation mask background - slightly darker for better contrast -->
  <g opacity="0.3">
    <path d="M80 50 Q85 80 82 110 Q78 140 85 170 Q92 200 85 235" 
          fill="none" stroke="#81C784" stroke-width="12" stroke-linecap="round"/>
    <path d="M78 80 Q60 95 45 115 Q30 135 25 155" 
          fill="none" stroke="#AED581" stroke-width="8" stroke-linecap="round"/>
    <path d="M85 115 Q105 130 120 155 Q132 180 135 205" 
          fill="none" stroke="#AED581" stroke-width="8" stroke-linecap="round"/>
  </g>

  <!-- 1. Uncorrected flawed skeleton (before state) - enhanced visibility -->
  <g>
    <!-- Broken primary root gap - thicker and more visible -->
    <path d="M80 50 Q82 80 80 110 Q78 135 75 160" 
          fill="none" stroke="url(#errorSkeleton)" stroke-width="2.5" stroke-dasharray="4,2" stroke-linecap="round"/>
    <path d="M82 175 Q88 205 85 235" 
          fill="none" stroke="url(#errorSkeleton)" stroke-width="2.5" stroke-dasharray="4,2" stroke-linecap="round"/>
    
    <!-- Stray incorrect branch - more prominent -->
    <path d="M60 105 Q52 120 48 138" 
          fill="none" stroke="url(#errorSkeleton)" stroke-width="2" stroke-dasharray="3,2" stroke-linecap="round"/>
    
    <!-- Wobbly misaligned secondary root - clearer wobble -->
    <path d="M82 112 Q95 122 102 135 Q98 150 105 165 Q100 178 108 190" 
          fill="none" stroke="url(#errorSkeleton)" stroke-width="2.2" stroke-dasharray="3,2" stroke-linecap="round"/>
  </g>

  <!-- 2. Corrected perfect skeleton (after state) - more prominent -->
  <g filter="url(#skeletonGlow)">
    <!-- Fixed primary root (bridges the gap) - slightly thicker -->
    <path d="M80 50 Q82 80 80 110 Q78 135 80 165 Q85 195 85 235" 
          fill="none" stroke="url(#correctedSkeleton)" stroke-width="3.2" stroke-linecap="round"/>
    
    <!-- Clean secondary root (removed stray branch) - more visible -->
    <path d="M78 80 Q60 95 45 115 Q30 135 25 155" 
          fill="none" stroke="url(#correctedSkeleton)" stroke-width="2.6" stroke-linecap="round"/>
    
    <!-- Straightened corrected secondary root - more visible -->
    <path d="M82 115 Q100 130 118 152 Q130 175 135 205" 
          fill="none" stroke="url(#correctedSkeleton)" stroke-width="2.6" stroke-linecap="round"/>
    
    <!-- Skeleton junction markers - larger and more prominent -->
    <circle cx="80" cy="50" r="3.5" fill="#4CAF50"/>
    <circle cx="80" cy="165" r="3.2" fill="#CDDC39"/>
    <circle cx="85" cy="235" r="3.5" fill="#4CAF50"/>
    <circle cx="25" cy="155" r="2.6" fill="#8BC34A"/>
    <circle cx="135" cy="205" r="2.6" fill="#8BC34A"/>
  </g>

  <!-- 3. Correction highlight points (where AI fixed errors) - enhanced visibility -->
  <g filter="url(#fixGlow)">
    <!-- Gap repair point - larger and clearer -->
    <circle cx="80" cy="165" r="6" fill="url(#correctionGlow)" opacity="0.7"/>
    <path d="M76 165 L84 165 M80 159 L80 171" fill="none" stroke="white" stroke-width="1.5"/>
    
    <!-- Stray branch removal indicator - clearer cross -->
    <circle cx="60" cy="105" r="5" fill="url(#correctionGlow)" opacity="0.6"/>
    <path d="M57 102 L63 108 M63 102 L57 108" fill="none" stroke="white" stroke-width="1.5"/>
    
    <!-- Alignment correction point - clearer target circle -->
    <circle cx="108" cy="165" r="5" fill="url(#correctionGlow)" opacity="0.6"/>
    <circle cx="108" cy="165" r="9" fill="none" stroke="white" stroke-width="1" stroke-dasharray="2,1.5"/>
  </g>

  <!-- 4. AI Processing Nodes focused near correction points - enhanced -->
  <g filter="url(#softGlow)">
    <circle cx="165" cy="75" r="9" fill="url(#aiGradient)" stroke="#7C4DFF" stroke-width="1.5"/>
    <circle cx="195" cy="105" r="7" fill="url(#aiGradient)" stroke="#536DFE" stroke-width="1.2"/>
    <circle cx="175" cy="135" r="8" fill="url(#aiGradient)" stroke="#7C4DFF" stroke-width="1.5"/>
    <circle cx="210" cy="155" r="6" fill="url(#aiGradient)" stroke="#448AFF" stroke-width="1.2"/>
    
    <!-- Connections linking AI to correction points - more visible -->
    <line x1="165" y1="84" x2="80" y2="165" stroke="#7C4DFF" stroke-width="1.5" opacity="0.6" stroke-dasharray="5,3"/>
    <line x1="195" y1="112" x2="60" y2="105" stroke="#536DFE" stroke-width="1.2" opacity="0.5" stroke-dasharray="4,2"/>
    <line x1="175" y1="143" x2="108" y2="165" stroke="#7C4DFF" stroke-width="1.2" opacity="0.5" stroke-dasharray="4,2"/>
  </g>

  <!-- 5. Integrated Submit Arrow with correction confirmation - enhanced -->
  <g filter="url(#softGlow)">
    <!-- Arrow body - slightly larger -->
    <path d="M162 206 L212 206 L212 188 L252 215 L212 242 L212 224 L162 224 Z" 
          fill="url(#arrowGradient)" stroke="#00796B" stroke-width="2.2" stroke-linejoin="round"/>
  </g>

  <!-- Data flow from corrected skeleton to submit arrow - enhanced -->
  <path d="M135 205 Q150 210 162 215" 
        fill="none" stroke="url(#aiGradient)" stroke-width="2.2" stroke-dasharray="4,2" opacity="0.6"/>

  <!-- Plant seedling context at top - enhanced -->
  <g>
    <path d="M80 50 Q80 38 80 28" fill="none" stroke="#43A047" stroke-width="5" stroke-linecap="round"/>
    <ellipse cx="68" cy="25" rx="13" ry="9" fill="#66BB6A" transform="rotate(-30, 68, 25)"/>
    <ellipse cx="92" cy="25" rx="13" ry="9" fill="#81C784" transform="rotate(30, 92, 25)"/>
  </g>

  <!-- Enhanced pulsing correction indicator - more prominent -->
  <circle cx="80" cy="165" r="10" fill="none" stroke="#7C4DFF" stroke-width="1.2" opacity="0.4">
    <animate attributeName="r" values="10;14;10" dur="2.5s" repeatCount="indefinite"/>
    <animate attributeName="opacity" values="0.4;0.15;0.4" dur="2.5s" repeatCount="indefinite"/>
  </circle>

  <!-- Additional visual cue: "FIXED" text alternative - subtle checkmark -->
  <g transform="translate(140, 60)" opacity="0.8">
    <rect x="-8" y="-8" width="16" height="16" rx="3" fill="#7C4DFF" opacity="0.3"/>
    <path d="M-5 0 L-2 3 L5 -4" fill="none" stroke="white" stroke-width="1.8" stroke-linecap="round"/>
  </g>
  
  <!-- Background overlay for text -->
  <rect x="0" y="200" width="256" height="56" fill="#1e1e2e" opacity="0.9" rx="0" ry="0"/>
  
  <!-- Function label -->
  <text x="128" y="240" text-anchor="middle" fill="#ffb86c" font-size="28" font-weight="bold" font-family="sans-serif" filter="url(#textGlow)">
    Skeleton Correction
  </text>
</svg>